#SBATCH --job-name=smart-extra
#SBATCH --account=mech-ai-scavenger
#SBATCH --qos=scavenger
#SBATCH --partition=scavenger
#SBATCH --gres=gpu:1
#SBATCH --constraint="a100|v100|l40s|h200|rtxpro6000"
#SBATCH --cpus-per-task=8
#SBATCH --mem=64G
#SBATCH --time=08:00:00
#SBATCH --requeue
#SBATCH --mail-user=tirtho@iastate.edu
#SBATCH --mail-type=END,FAIL
#SBATCH --output=/work/mech-ai-scratch/tirtho/RecusrsiveQFormer/logs/extra-%j.out
#SBATCH --error=/work/mech-ai-scratch/tirtho/RecusrsiveQFormer/logs/extra-%j.out
# Reviewer extras on the main 4-cohort task: multi-seed (5) + init/anneal 2x2x3.
# Resumable -> results_extra/{multiseed,init_anneal}/
set -uo pipefail
PROJ=/work/mech-ai-scratch/tirtho/RecusrsiveQFormer
PY=/work/mech-ai-scratch/tirtho/.venv/bin/python
cd "$PROJ"
export PYTHONUNBUFFERED=1
export OMP_NUM_THREADS=$SLURM_CPUS_PER_TASK
echo "[extra] host=$(hostname) date=$(date)"; nvidia-smi -L
$PY -m recursive_marker_transformer.extra_experiments --exp multiseed init_anneal --out results_extra
echo "[extra] DONE rc=$? date=$(date)"
